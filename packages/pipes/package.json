{
  "name": "@subsquid/pipes",
  "type": "module",
  "version": "1.0.0-alpha.17",
  "description": "TypeScript SDK for streaming blockchain data: tap SQD Portal sources, decode EVM/Solana/Bitcoin/Tron/Hyperliquid onchain data, handle reorgs, write to Postgres, ClickHouse, BigQuery, or Parquet.",
  "keywords": [
    "typescript",
    "blockchain",
    "ethereum",
    "evm",
    "solana",
    "bitcoin",
    "tron",
    "hyperliquid",
    "web3",
    "blockchain-indexer",
    "indexer",
    "etl",
    "data-pipeline",
    "streaming",
    "realtime",
    "clickhouse",
    "postgresql",
    "bigquery",
    "parquet",
    "subsquid"
  ],
  "sideEffects": false,
  "author": "Subsquid Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subsquid-labs/pipes-sdk.git",
    "directory": "packages/pipes"
  },
  "files": [
    "dist",
    "src",
    "!**/*.test.*",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsx scripts/build.js",
    "lint": "biome check . --write",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@dsnp/parquetjs": "1.8.7",
    "@google-cloud/bigquery": "8.3.0",
    "@google-cloud/bigquery-storage": "5.1.0",
    "@subsquid/borsh": "0.3.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "4.17.23",
    "@types/node": "22.14.1",
    "@types/pg": "8.15.6",
    "@vitest/coverage-v8": "3.2.4",
    "protobufjs": "7.5.0",
    "typescript": "5.9.2",
    "viem": "^2.45.1",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@subsquid/evm-abi": "0.3.1",
    "@subsquid/evm-codec": "0.3.0",
    "@subsquid/solana-stream": "0.3.1",
    "@subsquid/util-internal": "3.2.0",
    "@subsquid/util-internal-hex": "0.0.2",
    "@subsquid/util-internal-validation": "0.8.0",
    "@subsquid/util-timeout": "^2.3.2",
    "express": "5.1.0",
    "pino": "9.12.0",
    "pino-pretty": "13.1.1",
    "prom-client": "15.1.3"
  },
  "peerDependencies": {
    "@dsnp/parquetjs": "1.8.7",
    "@clickhouse/client": "1.14.0",
    "@google-cloud/bigquery": "8.3.0",
    "@google-cloud/bigquery-storage": "5.1.0",
    "@opentelemetry/api": "^1.9.0",
    "better-sqlite3": "12.4.5",
    "drizzle-orm": "0.44.7",
    "pg": "8.16.3",
    "protobufjs": "^7.2.4"
  },
  "peerDependenciesMeta": {
    "@dsnp/parquetjs": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "@clickhouse/client": {
      "optional": true
    },
    "@google-cloud/bigquery": {
      "optional": true
    },
    "@google-cloud/bigquery-storage": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "protobufjs": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./evm": {
      "browser": "./dist/evm/browser.js",
      "types": "./dist/evm/index.d.ts",
      "import": "./dist/evm/index.js",
      "require": "./dist/evm/index.cjs"
    },
    "./solana": {
      "types": "./dist/solana/index.d.ts",
      "import": "./dist/solana/index.js",
      "require": "./dist/solana/index.cjs"
    },
    "./hyperliquid": {
      "types": "./dist/hyperliquid/index.d.ts",
      "import": "./dist/hyperliquid/index.js",
      "require": "./dist/hyperliquid/index.cjs"
    },
    "./bitcoin": {
      "types": "./dist/bitcoin/index.d.ts",
      "import": "./dist/bitcoin/index.js",
      "require": "./dist/bitcoin/index.cjs"
    },
    "./tron": {
      "types": "./dist/tron/index.d.ts",
      "import": "./dist/tron/index.js",
      "require": "./dist/tron/index.cjs"
    },
    "./portal-client": {
      "types": "./dist/portal-client/index.d.ts",
      "import": "./dist/portal-client/index.js",
      "require": "./dist/portal-client/index.cjs"
    },
    "./portal-cache/node": {
      "types": "./dist/portal-cache/node/index.d.ts",
      "import": "./dist/portal-cache/node/index.js",
      "require": "./dist/portal-cache/node/index.cjs"
    },
    "./targets/bigquery": {
      "types": "./dist/targets/bigquery/index.d.ts",
      "import": "./dist/targets/bigquery/index.js",
      "require": "./dist/targets/bigquery/index.cjs"
    },
    "./targets/parquet": {
      "types": "./dist/targets/parquet/index.d.ts",
      "import": "./dist/targets/parquet/index.js",
      "require": "./dist/targets/parquet/index.cjs"
    },
    "./targets/clickhouse": {
      "types": "./dist/targets/clickhouse/index.d.ts",
      "import": "./dist/targets/clickhouse/index.js",
      "require": "./dist/targets/clickhouse/index.cjs"
    },
    "./targets/drizzle/node-postgres": {
      "types": "./dist/targets/drizzle/node-postgres/index.d.ts",
      "import": "./dist/targets/drizzle/node-postgres/index.js",
      "require": "./dist/targets/drizzle/node-postgres/index.cjs"
    },
    "./metrics/node": {
      "types": "./dist/metrics/node/index.d.ts",
      "import": "./dist/metrics/node/index.js",
      "require": "./dist/metrics/node/index.cjs"
    },
    "./runtime/node": {
      "browser": "./dist/runtime/node/browser.js",
      "types": "./dist/runtime/node/index.d.ts",
      "import": "./dist/runtime/node/index.js",
      "require": "./dist/runtime/node/index.cjs"
    },
    "./opentelemetry": {
      "types": "./dist/opentelemetry/index.d.ts",
      "import": "./dist/opentelemetry/index.js",
      "require": "./dist/opentelemetry/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    },
    "./testing/evm": {
      "types": "./dist/testing/evm/index.d.ts",
      "import": "./dist/testing/evm/index.js",
      "require": "./dist/testing/evm/index.cjs"
    },
    "./testing/bitcoin": {
      "types": "./dist/testing/bitcoin/index.d.ts",
      "import": "./dist/testing/bitcoin/index.js",
      "require": "./dist/testing/bitcoin/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "evm": [
        "./dist/evm/index.d.ts"
      ],
      "solana": [
        "./dist/solana/index.d.ts"
      ],
      "hyperliquid": [
        "./dist/hyperliquid/index.d.ts"
      ],
      "bitcoin": [
        "./dist/bitcoin/index.d.ts"
      ],
      "tron": [
        "./dist/tron/index.d.ts"
      ],
      "portal-client": [
        "./dist/portal-client/index.d.ts"
      ],
      "portal-cache/node": [
        "./dist/portal-cache/node/index.d.ts"
      ],
      "targets/bigquery": [
        "./dist/targets/bigquery/index.d.ts"
      ],
      "targets/parquet": [
        "./dist/targets/parquet/index.d.ts"
      ],
      "targets/clickhouse": [
        "./dist/targets/clickhouse/index.d.ts"
      ],
      "targets/drizzle/node-postgres": [
        "./dist/targets/drizzle/node-postgres/index.d.ts"
      ],
      "metrics/node": [
        "./dist/metrics/node/index.d.ts"
      ],
      "runtime/node": [
        "./dist/runtime/node/index.d.ts"
      ],
      "opentelemetry": [
        "./dist/opentelemetry/index.d.ts"
      ],
      "testing": [
        "./dist/testing/index.d.ts"
      ],
      "testing/evm": [
        "./dist/testing/evm/index.d.ts"
      ],
      "testing/bitcoin": [
        "./dist/testing/bitcoin/index.d.ts"
      ]
    }
  }
}
